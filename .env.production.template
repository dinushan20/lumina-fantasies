# Lumina Fantasies closed-beta launch template
# Every REQUIRED value must be replaced before launch.

# Domain URLs
WEB_APP_URL=REQUIRED_https://beta.luminafantasies.example.com
API_BASE_URL=REQUIRED_https://api.luminafantasies.example.com
NEXT_PUBLIC_API_BASE_URL=REQUIRED_https://api.luminafantasies.example.com

# Runtime
NODE_ENV=production
ENVIRONMENT=production

# Shared secrets
INTERNAL_API_SHARED_SECRET=REQUIRED_replace_with_a_long_random_shared_secret

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=REQUIRED_pk_live_replace_me
CLERK_SECRET_KEY=REQUIRED_sk_live_replace_me
CLERK_SIGN_IN_URL=/sign-in
CLERK_SIGN_UP_URL=/sign-up
CLERK_AFTER_SIGN_IN_URL=/onboarding
CLERK_AFTER_SIGN_UP_URL=/onboarding
AUTH_ADMIN_EMAILS=REQUIRED_admin@example.com

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=REQUIRED_pk_live_replace_me
STRIPE_SECRET_KEY=REQUIRED_sk_live_replace_me
STRIPE_WEBHOOK_SECRET=REQUIRED_whsec_replace_me
STRIPE_PRICE_BASIC_ID=REQUIRED_price_basic_live_replace_me
STRIPE_PRICE_PREMIUM_ID=REQUIRED_price_premium_live_replace_me
STRIPE_PRICE_VIP_ID=REQUIRED_price_vip_live_replace_me

# ElevenLabs
ELEVENLABS_API_KEY=REQUIRED_replace_with_live_key
ELEVENLABS_VOICE_ID=REQUIRED_replace_with_default_voice_id

# Database
DATABASE_URL=REQUIRED_postgresql+asyncpg://user:password@db-host:5432/lumina

# Redis
REDIS_URL=REQUIRED_redis://redis-host:6379/0

# LLM + moderation
LLM_PROVIDER=mock
LLM_MODEL=qwen3.5-32b-instruct
LLM_BASE_URL=REQUIRED_if_using_hosted_llm
LLM_API_KEY=REQUIRED_if_using_hosted_llm
MODERATION_PROVIDER=local-rules
MODERATION_MODEL=qwen3.5-moderation
CONSENT_SCORE_THRESHOLD=75
HUMAN_REVIEW_THRESHOLD=55
MODERATION_QUEUE_THRESHOLD=92
API_LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=REQUIRED_https://beta.luminafantasies.example.com
